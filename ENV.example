# GamePoint environment template — copy to .env (gitignored) and fill in.
# NEVER commit a filled-in copy. Server-side secrets belong in
# `supabase secrets set`, read via Deno.env.get(); this file documents names only.

# ── Supabase project ─────────────────────────────────────────────────────────
# Project URL and anon key are client-safe (anon key is public by design; RLS
# is the security boundary).
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=

# Service role key: SERVER-SIDE ONLY. Must never appear in the overlay bundle,
# the capture service binary, or any client-distributed artifact (Pre-Flight P2).
SUPABASE_SERVICE_ROLE_KEY=

# ── Inference providers ──────────────────────────────────────────────────────
# Primary vision/coaching models (Edge Functions only, via `supabase secrets set`).
OPENAI_API_KEY=
# Fallback provider, engaged by the router cost circuit breaker (WP-4).
GEMINI_API_KEY=

# ── Edge Function configuration ──────────────────────────────────────────────
# Comma-separated explicit origins. No wildcard in prod (APEX CORS pattern).
ALLOWED_ORIGINS=http://localhost:1420

# ── Observability (env-gated; leave empty to disable) ────────────────────────
SENTRY_DSN=

# ── Capture service (local desktop config, not a secret) ────────────────────
# gRPC dispatch endpoint for the capture service.
GAMEPOINT_DISPATCH_URL=https://YOUR-PROJECT-REF.supabase.co/functions/v1/assist
