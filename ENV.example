# Public web/overlay client values only. Never place service-role secrets in browser-exposed env vars.
# Must match the exact names read in apps/web/src/lib.tsx (VITE_SUPABASE_PUBLISHABLE_KEY,
# not VITE_SUPABASE_ANON_KEY) — the publishable key is Supabase's newer name for the
# client-safe key; supabaseConfigured is false and AppRoot shows a config-missing gate
# if either var is absent, with no hardcoded fallback.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_GAMEPOINT_DOWNLOAD_URL=
VITE_SUPPORTED_TITLES_SOURCE=fixture

# Server-side Supabase Edge Function values.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CORS_ALLOWED_ORIGINS=

# Model provider aliases. Values must be verified in deployment env; no model availability is assumed by code.
MODEL_PROVIDER_PRIMARY=
MODEL_PROVIDER_FALLBACK=
VISION_MODEL_PRIMARY=
VISION_MODEL_ESCALATION=
TEXT_EMBEDDING_MODEL=

# Cost and latency budgets for safe local fixtures.
ASSIST_MAX_INPUT_TOKENS=1200
ASSIST_MAX_OUTPUT_TOKENS=120
ASSIST_MAX_IMAGE_PIXELS=786432
ASSIST_MAX_ROIS=2
ASSIST_MAX_RETRIEVAL_CHUNKS=4
ASSIST_MAX_LATENCY_MS=1500
ASSIST_MAX_COST_USD_MICROS=500
ASSIST_ESCALATION_ALLOWED=false

# Added 2026-07-08 (WP-4/WP-6): router aliases + cost accounting (ADR-004; defaults documented, verify before deploy).
OPENAI_API_KEY=
OPENAI_BASE_URL=
GEMINI_API_KEY=
VISION_MODEL_FALLBACK=
COST_

# --- Hybrid model providers (ADR-009) — Supabase Edge Function secrets ONLY.
# Never VITE_-prefixed, never in Cloudflare or GitHub (charter invariant 10).
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
# Aliases are provider-prefixed: <provider>:<model>
VISION_MODEL_PRIMARY=groq:meta-llama/llama-4-scout-17b-16e-instruct
VISION_MODEL_ESCALATION=gemini:gemini-2.5-flash
VISION_MODEL_FALLBACK=gemini:gemini-flash-lite-latest
EMBEDDINGS_PROVIDER_ORDER=gemini,openai
