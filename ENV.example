# Public web/overlay client values only. Never place service-role secrets in browser-exposed env vars.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GAMEPOINT_DOWNLOAD_URL=
VITE_SUPPORTED_TITLES_SOURCE=fixture

# Server-side Supabase Edge Function values.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CORS_ALLOWED_ORIGINS=

# Model provider aliases. Values must be verified in deployment env; no model availability is assumed by code.
MODEL_PROVIDER_PRIMARY=
MODEL_PROVIDER_FALLBACK=
VISION_MODEL_PRIMARY=
VISION_MODEL_ESCALATION=
TEXT_EMBEDDING_MODEL=

# Cost and latency budgets for safe local fixtures.
ASSIST_MAX_INPUT_TOKENS=1200
ASSIST_MAX_OUTPUT_TOKENS=120
ASSIST_MAX_IMAGE_PIXELS=786432
ASSIST_MAX_ROIS=2
ASSIST_MAX_RETRIEVAL_CHUNKS=4
ASSIST_MAX_LATENCY_MS=1500
ASSIST_MAX_COST_USD_MICROS=500
ASSIST_ESCALATION_ALLOWED=false

# Added 2026-07-08 (WP-4/WP-6): router aliases + cost accounting (ADR-004; defaults documented, verify before deploy).
OPENAI_API_KEY=
OPENAI_BASE_URL=
GEMINI_API_KEY=
VISION_MODEL_FALLBACK=
COST_BREAKER_USD_MICROS=500
COST_INPUT_MICROS_PER_TOKEN=0.05
COST_OUTPUT_MICROS_PER_TOKEN=0.4
SENTRY_DSN=

# Supabase Auth redirect allowlist values to configure in the Supabase dashboard.
SUPABASE_AUTH_SITE_URL=https://gamepointagent.com
SUPABASE_AUTH_ADDITIONAL_REDIRECT_URLS=https://app.gamepointagent.com,http://localhost:5173
